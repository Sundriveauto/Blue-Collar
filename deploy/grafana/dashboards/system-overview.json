{
  "dashboard": {
    "title": "System Overview",
    "tags": ["system", "infrastructure"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "API Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(up{job=\"api\"}) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        },
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 2,
        "title": "Database Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"postgres\"}",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 3,
        "title": "Redis Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"redis\"}",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 6,
        "title": "Disk Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "(node_filesystem_size_bytes - node_filesystem_avail_bytes) / node_filesystem_size_bytes * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 7,
        "title": "Active Database Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "Network Traffic (In)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m])",
            "legendFormat": "{{ device }}"
          }
        ],
        "yaxes": [
          {
            "label": "Bytes/sec",
            "format": "Bps"
          }
        ]
      },
      {
        "id": 9,
        "title": "Network Traffic (Out)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_network_transmit_bytes_total[5m])",
            "legendFormat": "{{ device }}"
          }
        ],
        "yaxes": [
          {
            "label": "Bytes/sec",
            "format": "Bps"
          }
        ]
      },
      {
        "id": 10,
        "title": "Disk I/O (Read)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_disk_read_bytes_total[5m])",
            "legendFormat": "{{ device }}"
          }
        ],
        "yaxes": [
          {
            "label": "Bytes/sec",
            "format": "Bps"
          }
        ]
      },
      {
        "id": 11,
        "title": "Disk I/O (Write)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_disk_written_bytes_total[5m])",
            "legendFormat": "{{ device }}"
          }
        ],
        "yaxes": [
          {
            "label": "Bytes/sec",
            "format": "Bps"
          }
        ]
      }
    ]
  }
}
