# Monitoring, Logging, and Alerting Environment Variables

# ─── Prometheus ────────────────────────────────────────────────────────────
# No configuration needed - Prometheus reads from prometheus.yml

# ─── AlertManager ──────────────────────────────────────────────────────────
# Slack webhook URL for alert notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty service key for critical incident escalation
PAGERDUTY_SERVICE_KEY=YOUR_PAGERDUTY_SERVICE_KEY

# Email addresses for alert notifications
ALERT_EMAIL_CRITICAL=oncall@bluecollar.app
ALERT_EMAIL_SLA=sla@bluecollar.app

# SMTP configuration for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@bluecollar.app
SMTP_PASS=YOUR_SMTP_PASSWORD

# ─── Grafana ──────────────────────────────────────────────────────────────
# Admin password (change from default!)
GRAFANA_ADMIN_PASSWORD=your_secure_password_here

# ─── OpenTelemetry ────────────────────────────────────────────────────────
# OTLP exporter endpoint (where traces are sent)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Trace sampling ratio (0.0-1.0; lower values = fewer traces sampled)
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0  # Sample 100% of traces (reduce for production)

# ─── Logstash & Elasticsearch ────────────────────────────────────────────
# Elasticsearch configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=bluecollar

# Logstash configuration
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
LOGSTASH_PROTOCOL=tcp  # or udp

# ─── Database Exporter ────────────────────────────────────────────────────
# These must match your PostgreSQL credentials
DB_USER=bluecollar_user
DB_PASSWORD=your_db_password_here
DB_NAME=bluecollar_db

# ─── Application Metrics ──────────────────────────────────────────────────
# Metrics endpoint exposure (keep internal in production)
METRICS_ENDPOINT=/metrics
METRICS_AUTH_ENABLED=false  # Enable basic auth for /metrics in production

# ─── Retention & Storage ──────────────────────────────────────────────────
# Prometheus retention time (default: 30d)
PROMETHEUS_RETENTION=30d

# Elasticsearch log retention (documents older than this are deleted)
ELASTICSEARCH_LOG_RETENTION_DAYS=90

# Jaeger trace retention (default: 72h)
JAEGER_RETENTION_HOURS=168  # 7 days

# ─── Resource Limits ──────────────────────────────────────────────────────
# Memory limits for monitoring services (increase for production)
PROMETHEUS_MEMORY_LIMIT=2g
ELASTICSEARCH_MEMORY_LIMIT=2g
GRAFANA_MEMORY_LIMIT=1g
JAEGER_MEMORY_LIMIT=1g

# CPU limits
PROMETHEUS_CPU_LIMIT=1000m
ELASTICSEARCH_CPU_LIMIT=1000m
